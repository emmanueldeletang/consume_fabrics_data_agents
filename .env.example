# Required authentication settings
FABRIC_TENANT_ID=<your-tenant-id-or-domain>
FABRIC_ADMIN_CLIENT_ID=<your-service-principal-client-id>
FABRIC_ADMIN_CLIENT_SECRET=<your-service-principal-client-secret>

# App settings
MONGO_URI=<your-mongodb-connection-string>
AGENTS_CONFIG_PATH=config/agents.json
DEFAULT_AGENT_KEY=adventureworks

# Optional overrides
FABRIC_SCOPE=https://api.fabric.microsoft.com/.default
FABRIC_API_VERSION=2024-05-01-preview
